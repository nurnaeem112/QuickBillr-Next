l,{"className":"text-5xl font-black text-red-400 mb-2","children":"91%"}],["$","p",null,{"className":"text-[10px] font-bold uppercase tracking-widest opacity-60","children":"Of bills paid within 2 days of a phone call"}]]}],["$","div",null,{"className":"text-center p-8 bg-white/5 backdrop-blur-md rounded-3xl border border-white/10","children":[["$","p",null,{"className":"text-5xl font-black text-red-400 mb-2","children":"15%"}],["$","p",null,{"className":"text-[10px] font-bold uppercase tracking-widest opacity-60","children":"Revenue lost to uncollected manual billing"}]]}]]}],["$","div",null,{"className":"mt-12 text-center text-[10px] text-gray-500 italic","children":["Sources: ",["$","a",null,{"href":"https://www.nfib.com","target":"_blank","className":"underline","children":"NFIB Small Business Trends"}],", ",["$","a",null,{"href":"https://www.statista.com","target":"_blank","className":"underline","children":"Statista B2B Payment Data"}],"."]}]]}],["$","div",null,{"className":"absolute top-0 right-0 w-[500px] h-[500px] bg-red-600 rounded-full blur-[200px] opacity-10"}]]}],["$","section",null,{"className":"space-y-8","children":[["$","h2",null,{"className":"text-3xl font-bold text-gray-900 font-outfit text-center","children":"Copy & Paste Collection Scripts"}],["$","div",null,{"className":"space-y-6","children":[["$","div",null,{"className":"bg-red-50 p-8 rounded-[2.5rem] border border-red-100","children":[["$","h5",null,{"className":"font-bold text-red-700 mb-4 uppercase tracking-tighter","children":"The \"Graceful Reminder\" (Day 3)"}],["$","div",null,{"className":"bg-white p-6 rounded-2xl border border-red-200 text-sm font-mono text-gray-800 italic","children":["\"Hi [Client Name], just a quick note that ",["$","strong",null,{"children":"Invoice #[Number]"}]," was due on [Date]. We understand things get busy! You can settle this instantly using our ",["$","$L8",null,{"href":"/free-invoice-generator","className":"text-red-500 underline","children":"secure payment portal"}],". Thank you!\""]}]]}],["$","div",null,{"className":"bg-gray-100 p-8 rounded-[2.5rem] border border-gray-200","children":[["$","h5",null,{"className":"font-bold text-gray-700 mb-4 uppercase tracking-tighter","children":"The \"Firm Request\" (Day 15)"}],["$","div",null,{"className":"bg-white p-6 rounded-2xl border border-gray-300 text-sm font-mono text-gray-800 italic","children":["\"Hi [Client Name], we haven't received payment for [Project Name]. This bill is now 15 days past due. To avoid late fees specified in our ",["$","$L8",null,{"href":"/blog/estimate-vs-invoice","className":"text-red-500 underline","children":"original quote"}],", please settle the balance today. Let me know if there's an issue we can help with.\""]}]]}]]}]]}],["$","section",null,{"className":"prose prose-lg max-w-none text-gray-700 leading-relaxed grid grid-cols-1 lg:grid-cols-2 gap-16","children":[["$","div",null,{"className":"bg-red-900 text-white p-12 rounded-[3.5rem] shadow-xl","children":[["$","h3",null,{"className":"text-3xl font-black mb-6 text-red-400","children":"Formal Escalation (Day 30+)"}],["$","p",null,{"className":"mb-6 opacity-80","children":"When the scripts fail, it is time for formal action. Do not delay beyond 30 days, as the statistical likelihood of being paid drops by 50% for every month a bill sits idle."}],["$","ul",null,{"className":"space-y-4 text-sm font-bold","children":[["$","li",null,{"className":"flex items-center gap-2","children":[["$","span",null,{"className":"text-red-400","children":"01."}]," Send a Formal Demand Letter via Certified Mail."]}],["$","li",null,{"className":"flex items-center gap-2","children":[["$","span",null,{"className":"text-red-400","children":"02."}]," Apply the ",["$","$L8",null,{"href":"/blog/how-to-add-tax-and-discounts-to-an-invoice","className":"text-red-100 underline","children":"Agreed Late Fee"}],"."]}],["$","li",null,{"className":"flex items-center gap-2","children":[["$","span",null,{"className":"text-red-400",